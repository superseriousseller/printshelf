# PrintShelf environment variables

# App environment: production | staging | development
APP_ENV=development
APP_DOMAIN=printshelf.app
APP_URL=https://printshelf.app

# JWT signing key (REQUIRED in production). Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Postgres connection string. If unset, falls back to SQLite at data/printshelf.db
# DATABASE_URL=postgresql://user:pass@host:5432/printshelf

# CORS — comma-separated origins allowed to call the API
# Must include the Chrome extension origin: chrome-extension://<extension-id>
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Cloudflare R2 (for print photo uploads).
# If unset, uploads fall back to <repo>/uploads/photos/ on local disk
# and are served from /uploads/photos/{filename}.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=printshelf-uploads
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_PUBLIC_URL_BASE=https://cdn.printshelf.app

# Resend (transactional email — password reset)
# Sign up at resend.com, verify printshelf.app domain, then set these.
RESEND_API_KEY=
RESEND_FROM_EMAIL=PrintShelf <noreply@printshelf.app>

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=

# Sentry (optional)
SENTRY_DSN=

# Logging
LOG_LEVEL=INFO
